{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://safety.ai/schemas/llm-safety-mechanisms/v1.1.0",
  "title": "LLM Safety Mechanisms Dataset",
  "description": "Structural schemas for every dataset file. scripts/validate.py validates each data/*.json against the matching entry in $defs (file-level defs end in '_file'). Referential integrity (cross-file foreign keys) is NOT expressible here and is enforced separately by scripts/check_integrity.py, which validate.py also runs.",

  "$defs": {

    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type", "headquarters"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "name": {"type": "string", "minLength": 1},
        "type": {"type": "string", "enum": ["academic", "commercial"]},
        "headquarters": {"type": "string", "minLength": 1}
      }
    },
    "providers_file": {"type": "array", "items": {"$ref": "#/$defs/provider"}},

    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "family", "provider", "status", "version", "notes"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "family": {"type": "string"},
        "provider": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "status": {"type": "string",
                   "enum": ["active", "deprecated", "retired", "superseded", "unknown"]},
        "version": {"type": "string"},
        "notes": {"type": "string"},
        "statusDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "sources": {"type": "array", "items": {"type": "string", "format": "uri"}}
      }
    },
    "models_file": {
      "type": "object",
      "required": ["models"],
      "properties": {"models": {"type": "array", "items": {"$ref": "#/$defs/model"}}}
    },

    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "color"],
      "properties": {
        "id": {"type": "string", "pattern": "^cat-[a-z-]+$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
      }
    },
    "categories_file": {"type": "array", "items": {"$ref": "#/$defs/category"}},

    "risk_area": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "category"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z_]+$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "category": {"type": "string",
                     "enum": ["fairness", "privacy", "reliability", "safety",
                              "security", "transparency"]}
      }
    },
    "risk_areas_file": {"type": "array", "items": {"$ref": "#/$defs/risk_area"}},

    "lifecycle_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "order"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z-]+$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 0}
      }
    },
    "model_lifecycle_file": {"type": "array", "items": {"$ref": "#/$defs/lifecycle_stage"}},

    "nlu_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["primary_concept", "semantic_anchors", "entailment_hypothesis"],
      "properties": {
        "primary_concept": {"type": "string", "minLength": 1},
        "semantic_anchors": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "entailment_hypothesis": {"type": "string", "minLength": 1},
        "excluded_terms": {"type": "array", "items": {"type": "string"}}
      }
    },
    "technique": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "categoryId", "riskAreaIds",
                   "lifecycleStages", "nlu_profile"],
      "properties": {
        "id": {"type": "string", "pattern": "^tech-[a-z0-9-]+$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "categoryId": {"type": "string", "pattern": "^cat-[a-z-]+$"},
        "riskAreaIds": {"type": "array", "items": {"type": "string"}},
        "lifecycleStages": {"type": "array", "items": {"type": "string"}},
        "nlu_profile": {"$ref": "#/$defs/nlu_profile"},
        "status": {"type": "string", "enum": ["aspirational"]},
        "status_note": {"type": "string"}
      }
    },
    "techniques_file": {"type": "array", "items": {"$ref": "#/$defs/technique"}},

    "structure_node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "name"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "children": {"type": "array", "items": {"$ref": "#/$defs/structure_node"}}
      }
    },
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "url", "version", "structure"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "name": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "version": {"type": "string"},
        "structure": {"type": "array", "items": {"$ref": "#/$defs/structure_node"}}
      }
    },
    "standards_file": {
      "type": "object",
      "required": ["frameworks"],
      "properties": {"frameworks": {"type": "array", "items": {"$ref": "#/$defs/framework"}}}
    },

    "standards_map_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["techniqueId", "frameworkId", "codes", "relationship",
                   "mappingConfidence", "notes"],
      "properties": {
        "techniqueId": {"type": "string", "pattern": "^tech-[a-z0-9-]+$"},
        "frameworkId": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "codes": {"type": "array", "items": {"type": "string"}},
        "relationship": {"type": "string",
                         "enum": ["addresses", "defends", "mitigates", "supports"]},
        "mappingConfidence": {"type": "string",
                              "enum": ["indirect", "partial", "strong"]},
        "notes": {"type": "string"}
      }
    },
    "standards_mapping_file": {"type": "array", "items": {"$ref": "#/$defs/standards_map_entry"}},

    "content_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["document_purpose", "scope", "signal_strength", "technical_depth",
                   "temporal_focus", "language", "primary_topics", "excluded_topics"],
      "properties": {
        "document_purpose": {"type": "string",
          "enum": ["blog_post", "documentation", "model_card", "policy",
                   "primary_research", "system_card", "technical_report",
                   "transparency_assessment"]},
        "scope": {"type": "string",
          "enum": ["industry_wide", "model_family", "provider", "provider_wide",
                   "specific_model"]},
        "signal_strength": {"type": "string", "enum": ["high", "low", "medium"]},
        "technical_depth": {"type": "string",
          "enum": ["deep", "high", "low", "moderate", "shallow"]},
        "temporal_focus": {"type": "string",
          "enum": ["implemented", "mixed", "planned", "research"]},
        "language": {"type": "string"},
        "confidence_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "primary_topics": {"type": "array", "items": {"type": "string"}},
        "excluded_topics": {"type": "array", "items": {"type": "string"}},
        "no_safety_content": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    },
    "evidence_model_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelId"],
      "properties": {
        "modelId": {"type": "string"},
        "name": {"type": "string"}
      }
    },
    "evidence_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "url", "provider", "type", "origin",
                   "evidenceQuality", "content_metadata"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "provider": {"type": "string"},
        "type": {"type": "string",
          "enum": ["Blog Post", "Documentation", "Framework", "Guide", "Model Card",
                   "Paper", "Policy", "System Card", "Technical Report",
                   "Third-party Assessment", "Website"]},
        "origin": {"type": "string", "enum": ["provider", "third-party"]},
        "evidenceQuality": {"type": "string", "enum": ["primary", "secondary"]},
        "content_metadata": {"$ref": "#/$defs/content_metadata"},
        "models": {"type": "array", "items": {"$ref": "#/$defs/evidence_model_ref"}},
        "fmti_techniques": {"type": "array", "items": {"type": "string"}},
        "date_added": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
      }
    },
    "evidence_file": {
      "type": "object",
      "required": ["sources"],
      "properties": {"sources": {"type": "array", "items": {"$ref": "#/$defs/evidence_source"}}}
    },

    "commentary_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "author", "organization", "date", "title", "url",
                   "summary", "type", "sentiment", "techniqueIds"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "author": {"type": "string"},
        "organization": {"type": "string"},
        "date": {"type": "string"},
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "summary": {"type": "string"},
        "type": {"type": "string",
          "enum": ["academic_paper", "audit", "blog_post", "news_analysis", "report"]},
        "sentiment": {"type": "string",
          "enum": ["mixed", "negative", "neutral", "positive"]},
        "techniqueIds": {"type": "array", "items": {"type": "string"}}
      }
    },
    "commentary_file": {"type": "array", "items": {"$ref": "#/$defs/commentary_entry"}},

    "incident_source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["date", "title", "type", "url"],
      "properties": {
        "date": {"type": "string"},
        "title": {"type": "string"},
        "type": {"type": "string"},
        "url": {"type": "string", "format": "uri"}
      }
    },
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "aiidIncidentId", "aiidUrl", "date", "title", "description",
                   "severity", "status", "isLLMRelated", "providerIds", "modelIds",
                   "riskAreaIds", "techniqueIds", "sources"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "aiidIncidentId": {"type": "integer"},
        "aiidUrl": {"type": "string", "format": "uri"},
        "date": {"type": "string"},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "severity": {"type": "string", "enum": ["high", "low", "medium"]},
        "status": {"type": "string", "enum": ["confirmed"]},
        "isLLMRelated": {"type": "boolean"},
        "providerIds": {"type": "array", "items": {"type": "string"}},
        "modelIds": {"type": "array", "items": {"type": "string"}},
        "riskAreaIds": {"type": "array", "items": {"type": "string"}},
        "techniqueIds": {"type": "array", "items": {"type": "string"}},
        "sources": {"type": "array", "items": {"$ref": "#/$defs/incident_source"}}
      }
    },
    "incidents_file": {"type": "array", "items": {"$ref": "#/$defs/incident"}},

    "map_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text", "created_by"],
      "properties": {
        "text": {"type": "string"},
        "created_by": {"type": "string",
          "enum": ["manual", "nlu", "llm", "sashaagafonoff", "legacy"]},
        "active": {"type": "boolean"},
        "deleted_by": {"type": ["string", "null"],
          "enum": ["manual", "nlu", "llm", "sashaagafonoff", "system", null]},
        "grounding_failed": {"type": "boolean"},
        "llm_original": {"type": ["string", "null"]},
        "created_at": {"type": "string"},
        "passage": {"type": "string"}
      }
    },
    "map_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["techniqueId", "active", "evidence"],
      "properties": {
        "techniqueId": {"type": "string", "pattern": "^tech-[a-z0-9-]+$"},
        "active": {"type": "boolean"},
        "confidence": {"type": "string"},
        "deleted_by": {"type": ["string", "null"],
          "enum": ["manual", "nlu", "llm", "sashaagafonoff", "system", null]},
        "deletion_reason": {"type": "string"},
        "reasoning": {"type": "string"},
        "needs_review": {"type": "boolean"},
        "review_reason": {"type": "string"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/map_evidence"}}
      }
    },
    "model_technique_map_file": {
      "type": "object",
      "additionalProperties": {"type": "array", "items": {"$ref": "#/$defs/map_entry"}}
    }
  }
}
